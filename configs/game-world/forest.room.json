{
  "room_id": "forest",
  "name": "Whispering Woods",
  "tick_hz": 0.5,
  "history_capacity": 1000,
  "sensors": {
    "time_of_day": {
      "type": "float",
      "unit": "hour",
      "source": "game:world/time",
      "range": [0, 24],
      "alarm_range": [20, 24]
    },
    "creature_count": {
      "type": "integer",
      "unit": "mobs",
      "source": "game:entity-count/tag:hostile",
      "range": [0, 50],
      "alarm_range": [20, 50]
    },
    "weather": {
      "type": "integer",
      "unit": "weather_id",
      "source": "game:world/weather",
      "range": [0, 10],
      "alarm_range": null
    },
    "quest_active": {
      "type": "boolean",
      "unit": null,
      "source": "game:quest/forest-active",
      "range": null,
      "alarm_range": null
    }
  },
  "actuators": {
    "spawn_ambush": {
      "type": "boolean",
      "target": "game:action/spawn-ambush",
      "safe_default": false
    },
    "change_weather": {
      "type": "boolean",
      "target": "game:action/weather-event",
      "safe_default": false
    }
  },
  "alarms": [
    {
      "id": "night_fall",
      "condition": "time_of_day > 20",
      "cooldown_sec": 600,
      "severity": "info",
      "actions": ["spawn_hostile_creatures", "log"]
    },
    {
      "id": "overrun",
      "condition": "creature_count > 20",
      "cooldown_sec": 60,
      "severity": "warning",
      "actions": ["notify_players", "log"]
    }
  ],
  "metadata": {
    "location": "overworld_west",
    "hardware": "game-engine",
    "deployment": "game-world"
  }
}
